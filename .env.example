# Dominio del VPS (sin https://)
DOMAIN=serubix.com

# GitHub (para las imágenes en GHCR — se rellena automáticamente en CI)
GITHUB_REPOSITORY=tu-usuario/TFM

# Backend
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/serubix
JWT_SECRET=cambia-esto-por-un-secreto-seguro

# Frontend (variables públicas — visibles en el navegador)
NEXT_PUBLIC_API_URL=https://serubix.com/api
