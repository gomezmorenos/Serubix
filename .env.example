# Dominio del VPS (sin https://)
DOMAIN=serubix.com

# Auth.js (NextAuth v5)
# Genera con: openssl rand -base64 32
AUTH_SECRET=cambia-esto-por-un-secreto-seguro-de-32-bytes

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI autorizada: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=tu-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=tu-google-client-secret

# GitHub (para las imágenes en GHCR — se rellena automáticamente en CI)
GITHUB_REPOSITORY=tu-usuario/TFM

# Base de datos (usadas por docker-compose y el backend)
POSTGRES_USER=serubix
POSTGRES_PASSWORD=cambia-esto-por-una-password-segura
POSTGRES_DB=serubix

# Backend
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
JWT_SECRET=cambia-esto-por-un-secreto-seguro

# Frontend (variables públicas — visibles en el navegador)
NEXT_PUBLIC_API_URL=https://serubix.com/api
